---
// Hero.astro — "cuerpo & mente" — ampersand in Gotu (same as headings)
---

<section class="relative w-full h-screen overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img
            src="/hero-massage.jpg"
            alt="NR Balance — Masaje y psicología"
            class="hero-bg w-full h-full object-cover md:object-center"
            style="object-position: 75% 50%;"
        />
        <div class="absolute inset-0 bg-base/20 md:bg-base/15"></div>
        <div
            class="absolute inset-0 bg-gradient-to-t from-base via-transparent to-base/50 md:hidden opacity-90"
        >
        </div>
    </div>

    <div
        class="relative z-10 flex flex-col items-center justify-end md:justify-center h-full text-center px-6 pb-[15vh] md:pb-0"
    >
        <h1
            class="hero-title font-serif leading-[0.9] md:leading-[1.1] tracking-[0.8px] text-main font-normal lowercase flex flex-col md:flex-row items-center gap-0 md:gap-8"
        >
            <span
                class="hero-word text-[70px] md:text-[80px] lg:text-[110px] xl:text-[130px]"
                >cuerpo</span
            >
            <span
                class="hero-amp text-[40px] md:text-[48px] lg:text-[60px] xl:text-[68px] text-peach"
                >&</span
            >
            <span
                class="hero-word text-[70px] md:text-[80px] lg:text-[110px] xl:text-[130px]"
                >mente</span
            >
        </h1>

        <p
            class="hero-subtitle font-sans text-[12px] uppercase tracking-[0.2em] text-main/60 mt-8 md:mt-8 font-bold"
        >
            Conecta contigo mismo
        </p>

        <a
            href="#services"
            class="hero-cta pill-btn pill-btn--primary mt-8 md:mt-14 px-[30px] py-[15px]"
        >
            <span class="text-[14px]">✳︎</span>
            <span class="text-[14px] font-bold"
                >Descubre nuestros servicios</span
            >
        </a>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // Initial states
        gsap.set(".hero-word", { opacity: 0 });
        gsap.set(".hero-amp", { y: 30, opacity: 0 });
        gsap.set(".hero-subtitle", { y: 20, opacity: 0 });
        gsap.set(".hero-cta", { y: 20, opacity: 0 });

        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

        // 1. Words fade in
        tl.to(".hero-word", {
            opacity: 1,
            duration: 1.5,
            delay: 0.5,
        })
            // 2. Ampersand slides up + fades (200ms delay approximately)
            .to(
                ".hero-amp",
                {
                    y: 0,
                    opacity: 1,
                    duration: 1.2,
                },
                "-=1.0",
            )
            // 3. Subtitle and CTA
            .to(".hero-subtitle", { y: 0, opacity: 1, duration: 1 }, "-=0.6")
            .to(".hero-cta", { y: 0, opacity: 1, duration: 1 }, "-=0.8");
    });
</script>
