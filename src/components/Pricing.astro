---
// Pricing.astro - Minimalist Editorial Pricing List
---

<section id="pricing" class="bg-secondary py-20 md:py-32">
    <div class="section-container">
        <div
            class="flex flex-col md:flex-row justify-between items-start mb-16 md:mb-24 gap-8"
        >
            <h2
                class="font-serif text-[36px] md:text-[60px] leading-[1.1] tracking-tighter text-main"
            >
                Inversión en<br />tu equilibrio.
            </h2>
            <p
                class="text-[16px] text-main/60 leading-[1.6] max-w-sm md:text-right"
            >
                Tarifas diseñadas con transparencia. Sesiones que se adaptan a
                la profundidad de tu proceso personal.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            <!-- Psicología Column -->
            <div class="pricing-column flex flex-col">
                <h3
                    class="font-sans text-[12px] font-bold tracking-[0.2em] uppercase text-main/40 mb-8 pb-4 border-b border-main/10"
                >
                    Psicología Clínica
                </h3>

                <div class="flex flex-col gap-6">
                    <div
                        class="flex justify-between items-end border-b border-main/5 pb-4 group cursor-pointer hover:border-main/30 transition-colors"
                    >
                        <div>
                            <h4
                                class="font-serif text-[20px] text-main group-hover:text-accent-luxury transition-colors"
                            >
                                Sesión Individual
                            </h4>
                            <span class="text-[14px] text-main/50"
                                >60 Minutos</span
                            >
                        </div>
                        <span class="font-serif text-[22px] text-main">40€</span
                        >
                    </div>

                    <div
                        class="flex justify-between items-end border-b border-main/5 pb-4 group cursor-pointer hover:border-main/30 transition-colors"
                    >
                        <div>
                            <h4
                                class="font-serif text-[20px] text-main group-hover:text-accent-luxury transition-colors"
                            >
                                Bono 4 Sesiones
                            </h4>
                            <span class="text-[14px] text-main/50"
                                >Validez 2 meses</span
                            >
                        </div>
                        <span class="font-serif text-[22px] text-main"
                            >140€</span
                        >
                    </div>
                </div>
            </div>

            <!-- Terapia Manual Column -->
            <div class="pricing-column flex flex-col">
                <h3
                    class="font-sans text-[12px] font-bold tracking-[0.2em] uppercase text-main/40 mb-8 pb-4 border-b border-main/10"
                >
                    Terapia Manual Avanzada
                </h3>

                <div class="flex flex-col gap-6">
                    <div
                        class="flex justify-between items-end border-b border-main/5 pb-4 group cursor-pointer hover:border-main/30 transition-colors"
                    >
                        <div>
                            <h4
                                class="font-serif text-[20px] text-main group-hover:text-accent-luxury transition-colors"
                            >
                                Masaje Relajante
                            </h4>
                            <span class="text-[14px] text-main/50"
                                >60 Minutos</span
                            >
                        </div>
                        <span class="font-serif text-[22px] text-main">35€</span
                        >
                    </div>

                    <div
                        class="flex justify-between items-end border-b border-main/5 pb-4 group cursor-pointer hover:border-main/30 transition-colors"
                    >
                        <div>
                            <h4
                                class="font-serif text-[20px] text-main group-hover:text-accent-luxury transition-colors"
                            >
                                Deep Tissue (Espalda/Cuello)
                            </h4>
                            <span class="text-[14px] text-main/50"
                                >45 Minutos</span
                            >
                        </div>
                        <span class="font-serif text-[22px] text-main">30€</span
                        >
                    </div>

                    <div
                        class="flex justify-between items-end border-b border-main/5 pb-4 group cursor-pointer hover:border-main/30 transition-colors"
                    >
                        <div class="flex items-center gap-3">
                            <div>
                                <h4
                                    class="font-serif text-[20px] text-main group-hover:text-accent-luxury transition-colors"
                                >
                                    Sesión Integrativa
                                </h4>
                                <span class="text-[14px] text-main/50"
                                    >Masaje + Regulación Somática (90 min)</span
                                >
                            </div>
                            <span
                                class="hidden md:inline-block px-2 py-1 bg-peach/50 text-accent-luxury text-[10px] uppercase font-bold tracking-widest rounded-full"
                                >Recomendado</span
                            >
                        </div>
                        <span class="font-serif text-[22px] text-main"
                            >55€</span
                        >
                    </div>
                </div>
            </div>
        </div>

        <!-- Programa Integral Full Width Banner -->
        <div class="mt-16 lg:mt-24">
            <div class="pricing-column flex flex-col md:flex-row justify-between items-start md:items-center gap-8 bg-main p-8 md:p-12 rounded-[32px] shadow-2xl relative overflow-hidden group hover:shadow-[0_20px_60px_rgba(191,160,113,0.15)] transition-all duration-700 border border-accent-luxury/20">
                <div class="absolute inset-0 z-0 opacity-20 mix-blend-multiply grayscale transition-opacity duration-700 group-hover:opacity-40">
                    <img src="/treatment_integral.png" alt="Programa Integral" class="w-full h-full object-cover" />
                </div>
                
                <div class="relative z-10 flex flex-col gap-3 max-w-xl">
                    <span class="font-sans text-[10px] md:text-[12px] font-bold tracking-[0.3em] uppercase text-accent-luxury block">
                        Tratamiento 360º de Alto Rendimiento
                    </span>
                    <h3 class="font-serif text-[32px] md:text-[40px] leading-[1.1] tracking-tight text-base mb-1 group-hover:text-accent-luxury transition-colors duration-500">
                        El Método NR Balance
                    </h3>
                    <p class="text-[14px] md:text-[15px] text-base/80 leading-[1.6] italic border-l-2 border-accent-luxury pl-4 mb-2">
                        "Sabemos que dar el paso impone respeto. Nuestras tarifas rompen la barrera económica para que el dinero no sea una excusa. El verdadero precio será tu esfuerzo y compromiso."
                    </p>
                    <p class="text-[14px] md:text-[16px] text-base/60 leading-[1.6]">
                        Plan Mensual Intensivo. Incluye sesiones quincenales de Psicología, Terapia Manual Profunda y planificación semanal de Acondicionamiento (AFDA0210).
                    </p>
                </div>

                <div class="relative z-10 flex flex-col items-start md:items-end gap-2 shrink-0 border-t md:border-t-0 border-accent-luxury/20 pt-6 md:pt-0 w-full md:w-auto">
                    <span class="font-serif text-[40px] md:text-[50px] text-base leading-none">250€</span>
                    <span class="text-[14px] text-accent-luxury/80 uppercase tracking-widest font-bold">Suscripción Mensual</span>
                    <span class="text-[12px] text-base/50 mb-2">Plazas muy limitadas</span>
                    <a href="https://wa.me/34600000000?text=Hola%20Natalia,%20necesito%20un%20cambio.%20Me%20interesa%20la%20valoración%20para%20el%20Método%20NR." target="_blank" class="pill-btn bg-accent-luxury text-main border-none hover:bg-white custom-cursor-hover text-[14px] px-6 py-3 mt-2">
                        Solicitar por WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener("astro:page-load", () => {
        gsap.registerPlugin(ScrollTrigger);

        // Setup stagger for each individual pricing item instead of the whole column
        const pricingGroups = document.querySelectorAll(".pricing-column");

        pricingGroups.forEach((group) => {
            const items = group.querySelectorAll(".group");
            gsap.from(items, {
                y: 30,
                scale: 0.95,
                opacity: 0,
                duration: 0.6,
                stagger: 0.15,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: group,
                    start: "top 85%",
                },
            });
        });
    });
</script>
