---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Dualidad from "../components/Dualidad.astro";
import TriageQuiz from "../components/TriageQuiz.astro";
import MarqueeTransition from "../components/MarqueeTransition.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Founder from "../components/Founder.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import Blog from "../components/Blog.astro";
import Footer from "../components/Footer.astro";
import BookingSystem from "../components/BookingSystem.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
---

<MainLayout title="NR Balance | Estudio de Bienestar y Masaje">
	<Hero />
	<Dualidad />
	<TriageQuiz />
	<About />
	<Founder />
	<MarqueeTransition />
	<Services />
	<Pricing />

	<section
		id="booking"
		class="py-24 md:py-32 bg-main relative overflow-hidden"
	>
		<!-- Subtle background grain/texture -->
		<div
			class="absolute inset-0 opacity-10 mix-blend-overlay pointer-events-none"
		>
		</div>

		<div
			class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col items-center"
		>
			<span
				class="text-[12px] font-bold tracking-[0.2em] uppercase text-accent-luxury mb-4 text-center block"
			>
				Agenda tu cita
			</span>
			<h2
				class="font-serif text-[40px] md:text-[60px] leading-[1.1] tracking-tight text-base mb-16 text-center"
			>
				Prioriza tu bienestar
			</h2>

			<BookingSystem />
		</div>
	</section>

	<GoogleReviews />
	<FAQ />
	<Blog />
	<Footer />
</MainLayout>
