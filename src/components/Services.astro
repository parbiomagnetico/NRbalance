---
// Services.astro - Sticky Split-Screen & Stacking Cards Experience
const psychServices = [
    {
        title: "Gestión de Ansiedad y Estrés",
        tag: "Psicoterapia / Somática",
        desc: "Nuestro protocolo clínico estrella. Conectamos los síntomas físicos hiperactivos con su raíz mental para desactivar los detonantes de alerta y restaurar el equilibrio nervioso.",
        href: "/servicios/mente/gestion-ansiedad",
    },
    {
        title: "Estado de Ánimo y Autoestima",
        tag: "Abordaje Estructurado",
        desc: "Intervención clínica para episodios de depresión, desmotivación o crisis vitales, guiando al paciente hacia la recuperación de su funcionalidad y valoración personal.",
        href: "/servicios/mente/estado-animo",
    },
    {
        title: "Recuperación de Trauma (Acoso / Mobbing)",
        tag: "Intervención Clínica",
        desc: "Acompañamiento especializado y riguroso para procesar vivencias traumáticas (bullying, mobbing, estrés postraumático) reconfigurando la red de memoria y la respuesta somática.",
        href: "/servicios/mente/recuperacion-trauma",
    },
    {
        title: "Terapia de Pareja y Relaciones",
        tag: "Terapia Relacional",
        desc: "Espacio de resolución de conflictos crónicos, mejora de canales de comunicación y abordaje profesional de la dependencia emocional o crisis de apego.",
        href: "/servicios/mente/terapia-pareja",
    },
];

const manualServices = [
    {
        title: "Masaje de Tejido Profundo y Descarga",
        tag: "Fisiología / Biomecánica",
        desc: "Intervención física intensa enfocada en las capas profundas del músculo y la fascia. Deshace adherencias, mejora el rango de movilidad y reduce la rigidez mecánica.",
        href: "/servicios/cuerpo/masaje-tejido-profundo",
    },
    {
        title: "Masaje de Descompresión Física",
        tag: "Sistema Nervioso",
        desc: "Protocolo que actúa sobre el sistema nervioso autónomo. Baja el cortisol y la frecuencia cardíaca, forzando fisiológicamente al cuerpo a salir del estado de alerta hacia el descanso.",
        href: "/servicios/cuerpo/descompresion-fisica",
    },
    {
        title: "Crio-Recuperación y Drenaje",
        tag: "Recuperación / Circulación",
        desc: "Uso de vasoconstricción y frío localizado para reducir inflamación tisular, acelerar el retorno venoso y facilitar el drenaje linfático periférico.",
        href: "/servicios/cuerpo/crio-recuperacion",
    },
    {
        title: "Descompresión Cervico-Mandibular",
        tag: "Foco Tensional",
        desc: "Intervención manual hiperfocalizada en maseteros, cuello y base del cráneo para aliviar la tensión mecánica por bruxismo y prevenir cefaleas tensionales asociadas al estrés.",
        href: "/servicios/cuerpo/descompresion-cervico-mandibular",
    },
];

const integralServices = [
    {
        title: "Programa Integral: Método NR",
        tag: "Psicología + Terapia Manual + AFDA0210",
        desc: "Transformación anatómica y emocional 360º. Un abordaje clínico inmersivo paso a paso para personas bloqueadas por traumas como el acoso escolar (bullying), depresión severa o descontento físico paralizante. Recupera el orgullo vital.",
        href: "/servicios/integral/metodo-nr",
    }
];
---

<section id="services" class="bg-base relative w-full pb-24 md:pb-32">
    <!-- HEADER SECTION -->
    <div
        class="px-6 md:px-12 py-24 md:py-32 flex flex-col items-center justify-center border-b border-main/10 bg-secondary relative overflow-hidden"
    >
        <div
            class="absolute inset-0 z-0 opacity-10 mix-blend-multiply grayscale"
        >
            <img
                src="/psych_services.png"
                alt="Background"
                class="w-full h-full object-cover"
            />
        </div>
        <div class="relative z-10 text-center">
            <span
                class="text-[12px] md:text-[14px] font-bold tracking-[0.3em] uppercase text-accent-luxury mb-6 block"
            >
                Nuestros Protocolos
            </span>
            <h2
                class="font-serif text-[50px] md:text-[90px] lg:text-[120px] leading-[0.9] tracking-tighter text-main mb-8"
            >
                Tratamientos<br /><span class="italic text-base/80 font-light"
                    >Clínicos.</span
                >
            </h2>
        </div>
    </div>

    <!-- CATEGORY 1: MENTE -->
    <div
        class="w-full relative flex flex-col lg:flex-row border-b border-main/10"
    >
        <!-- Lado Izquierdo Fijo (Desktop) -->
        <div
            class="lg:w-1/2 lg:sticky lg:top-0 h-auto lg:h-[100vh] flex flex-col justify-center p-8 md:p-16 lg:p-24 bg-main text-base overflow-hidden relative"
        >
            <div
                class="absolute inset-0 z-0 opacity-20 mix-blend-multiply grayscale"
            >
                <img
                    src="/psych_services.png"
                    alt="Psicología"
                    class="w-full h-full object-cover"
                />
            </div>

            <div class="relative z-10">
                <span
                    class="font-sans text-[12px] md:text-[14px] font-bold tracking-[0.3em] uppercase text-accent-luxury mb-4 block"
                >
                    I. Área de Psicología
                </span>
                <h3
                    class="font-serif text-[50px] md:text-[80px] leading-[0.9] tracking-tighter text-base"
                >
                    La <span class="italic text-peach">Mente.</span>
                </h3>
                <p class="mt-8 text-base/70 max-w-sm text-[16px] leading-[1.6]">
                    Abordamos el origen del bloqueo. Un espacio seguro para
                    desatar nudos emocionales y sanar a través de la palabra.
                </p>
            </div>
        </div>

        <!-- Lado Derecho Scrollable (Tarjetas) -->
        <div
            class="lg:w-1/2 p-6 md:p-12 lg:p-24 bg-base flex flex-col gap-6 md:gap-12 custom-cursor-hover"
        >
            {
                psychServices.map((srv, index) => (
                    <a
                        href={srv.href}
                        class="service-card sticky-stack w-full bg-[#FFFFFF] border border-main/10 p-8 md:p-12 rounded-[32px] shadow-sm flex flex-col gap-6 transition-all duration-500 group cursor-pointer"
                        style={`top: ${100 + index * 20}px; z-index: ${10 + index}; display: block;`}
                    >
                        <div class="flex flex-col gap-2">
                            <span class="text-accent-luxury text-[10px] md:text-[12px] font-mono tracking-widest uppercase mb-2">
                                {srv.tag}
                            </span>
                            <h4 class="font-serif text-[28px] md:text-[40px] leading-[1.1] tracking-tight text-main group-hover:text-accent-luxury transition-colors duration-500">
                                {srv.title}
                            </h4>
                        </div>
                        <p class="text-[15px] md:text-[16px] text-main/80 leading-[1.6]">
                            {srv.desc}
                        </p>
                        <div class="mt-4 pt-6 border-t border-main/5 flex justify-between items-center opacity-50 group-hover:opacity-100 transition-opacity">
                            <span class="text-[10px] uppercase font-bold tracking-widest text-main">
                                Saber más
                            </span>
                            <svg
                                class="w-5 h-5 text-main rotate-45 group-hover:rotate-0 transition-transform duration-300"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                                />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>

    <!-- CATEGORY 2: CUERPO -->
    <div class="w-full relative flex flex-col lg:flex-row">
        <!-- Lado Izquierdo Fijo (Desktop) -->
        <div
            class="lg:w-1/2 lg:sticky lg:top-0 h-auto lg:h-[100vh] flex flex-col justify-center p-8 md:p-16 lg:p-24 bg-peach text-main overflow-hidden relative border-t lg:border-t-0 border-main/10"
        >
            <div
                class="absolute inset-0 z-0 opacity-10 mix-blend-multiply grayscale"
            >
                <img
                    src="/premium_massage.png"
                    alt="Cuerpo"
                    class="w-full h-full object-cover"
                />
            </div>

            <div class="relative z-10">
                <span
                    class="font-sans text-[12px] md:text-[14px] font-bold tracking-[0.3em] uppercase text-main/60 mb-4 block"
                >
                    II. Terapia Manual
                </span>
                <h3
                    class="font-serif text-[50px] md:text-[80px] leading-[0.9] tracking-tighter text-main"
                >
                    El <span class="italic text-base/80">Cuerpo.</span>
                </h3>
                <p class="mt-8 text-main/70 max-w-sm text-[16px] leading-[1.6]">
                    El cuerpo es el mapa de tus experiencias. Restauramos la
                    memoria celular mediante tejido profundo y biomecánica
                    avanzada.
                </p>
            </div>
        </div>

        <!-- Lado Derecho Scrollable (Tarjetas) -->
        <div
            class="lg:w-1/2 p-6 md:p-12 lg:p-24 bg-secondary flex flex-col gap-6 md:gap-12 custom-cursor-hover"
        >
            {
                manualServices.map((srv, index) => (
                    <a
                        href={srv.href}
                        class="service-card sticky-stack w-full bg-[#FFFFFF] border border-main/10 p-8 md:p-12 rounded-[32px] shadow-sm flex flex-col gap-6 transition-all duration-500 group cursor-pointer"
                        style={`top: ${100 + index * 20}px; z-index: ${10 + index}; display: block;`}
                    >
                        <div class="flex flex-col gap-2">
                            <span class="text-accent-luxury text-[10px] md:text-[12px] font-mono tracking-widest uppercase mb-2">
                                {srv.tag}
                            </span>
                            <h4 class="font-serif text-[28px] md:text-[40px] leading-[1.1] tracking-tight text-main group-hover:text-accent-luxury transition-colors duration-500">
                                {srv.title}
                            </h4>
                        </div>
                        <p class="text-[15px] md:text-[16px] text-main/80 leading-[1.6]">
                            {srv.desc}
                        </p>
                        <div class="mt-4 pt-6 border-t border-main/5 flex justify-between items-center opacity-50 group-hover:opacity-100 transition-opacity">
                            <span class="text-[10px] uppercase font-bold tracking-widest text-main">
                                Saber más
                            </span>
                            <svg
                                class="w-5 h-5 text-main rotate-45 group-hover:rotate-0 transition-transform duration-300"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                                />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>

    <!-- CATEGORY 3: PROGRAMA INTEGRAL -->
    <div class="w-full relative flex flex-col lg:flex-row border-t border-main/10">
        <!-- Lado Izquierdo Fijo (Desktop) -->
        <div
            class="lg:w-1/2 lg:sticky lg:top-0 h-auto lg:h-[100vh] flex flex-col justify-center p-8 md:p-16 lg:p-24 bg-main text-base overflow-hidden relative"
        >
            <div
                class="absolute inset-0 z-0 opacity-40 mix-blend-multiply grayscale"
            >
                <img
                    src="/treatment_integral.png"
                    alt="Programa Integral"
                    class="w-full h-full object-cover"
                />
            </div>

            <div class="relative z-10">
                <span
                    class="font-sans text-[12px] md:text-[14px] font-bold tracking-[0.3em] uppercase text-accent-luxury mb-4 block"
                >
                    III. Tratamiento 360º
                </span>
                <h3
                    class="font-serif text-[50px] md:text-[80px] leading-[0.9] tracking-tighter text-base"
                >
                    El <span class="italic text-accent-luxury">Método.</span>
                </h3>
                <p class="mt-8 text-base/70 max-w-sm text-[16px] leading-[1.6]">
                    Nuestra joya clínica. La fusión total de psicología clínica, fisiología manual y acondicionamiento activo guiado (AFDA0210) para un cambio radical.
                </p>
            </div>
        </div>

        <!-- Lado Derecho Scrollable (Tarjetas) -->
        <div
            class="lg:w-1/2 p-6 md:p-12 lg:p-24 bg-base flex flex-col gap-6 md:gap-12 custom-cursor-hover"
        >
            {
                integralServices.map((srv, index) => (
                    <a
                        href={srv.href}
                        class="service-card sticky-stack w-full bg-main border border-accent-luxury/20 p-8 md:p-12 rounded-[32px] shadow-[0_10px_40px_rgba(191,160,113,0.1)] flex flex-col gap-6 transition-all duration-500 group cursor-pointer"
                        style={`top: ${100 + index * 20}px; z-index: ${10 + index}; display: block;`}
                    >
                        <div class="flex flex-col gap-2">
                            <span class="text-accent-luxury text-[10px] md:text-[12px] font-mono tracking-widest uppercase mb-2">
                                {srv.tag}
                            </span>
                            <h4 class="font-serif text-[28px] md:text-[40px] leading-[1.1] tracking-tight text-base group-hover:text-accent-luxury transition-colors duration-500">
                                {srv.title}
                            </h4>
                        </div>
                        <p class="text-[15px] md:text-[16px] text-base/80 leading-[1.6]">
                            {srv.desc}
                        </p>
                        <div class="mt-4 pt-6 border-t border-accent-luxury/20 flex justify-between items-center opacity-70 group-hover:opacity-100 transition-opacity">
                            <span class="text-[10px] uppercase font-bold tracking-widest text-accent-luxury">
                                Descubrir el Método
                            </span>
                            <svg
                                class="w-5 h-5 text-accent-luxury rotate-45 group-hover:rotate-0 transition-transform duration-300"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                                />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* Efecto premium de apilamiento para las tarjetas */
    .sticky-stack {
        position: sticky;
        transform-origin: top center;
        background-color: var(--color-base);
        will-change: transform, filter;
    }

    /* En móviles (y desktop derecho), cuando la tarjeta toca su tope sticky, 
       se oscurecerá sutilmente si hay otra tarjeta pasando por encima */
    .service-card {
        background-color: var(--color-base);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener("astro:page-load", () => {
        gsap.registerPlugin(ScrollTrigger);

        // Stacking Cards Parallax Effect - Scaling down cards that are "stuck"
        const cards = gsap.utils.toArray(".sticky-stack") as HTMLElement[];

        cards.forEach((card, i) => {
            // Animar cada tarjeta basándose en cómo se superpone la siguiente
            ScrollTrigger.create({
                trigger: card,
                start: `top ${card.style.top}`, // Cuando la tarjeta llega a su punto sticky
                endTrigger: cards[i + 1] ? cards[i + 1] : card, // Hasta que la siguiente tarjeta la toque
                end: `top ${cards[i + 1] ? cards[i + 1].style.top : "bottom"}`,
                scrub: true,
                animation: gsap.to(card, {
                    scale: 0.95,
                    filter: "brightness(0.9)", // Oscurece ligeramente
                    ease: "none",
                }),
            });
        });
    });
</script>
