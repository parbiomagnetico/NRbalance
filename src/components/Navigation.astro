            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class="font-sans text-[14px] font-medium text-main/80 hover:text-main transition-colors duration-300 tracking-[0.2px] flex items-center gap-1"
                    >
                        {item.label}
                        {item.hasDropdown && (
                            <span class="text-[8px] opacity-40">▼</span>
                        )}
                    </a>
                ))
            }
        </nav>

        <a
            href="#pricing"
            class="hidden lg:inline-flex pill-btn pill-btn--primary"
        >
            <span class="text-[14px]">✳︎</span>
            Reservar
        </a>

        <button
            id="mobile-menu-toggle"
            class="lg:hidden flex flex-col gap-[6px] p-2"
            aria-label="Menú"
        >
            <span
                class="hamburger-line block w-6 h-[2px] bg-main transition-all duration-300 origin-center"
            ></span>
            <span
                class="hamburger-line block w-6 h-[2px] bg-main transition-all duration-300 origin-center"
            ></span>
        </button>
    </div>

    <div
        id="mobile-menu"
        class="lg:hidden fixed inset-0 bg-base z-[99] flex flex-col items-center justify-center gap-6 opacity-0 pointer-events-none transition-opacity duration-500"
        style="visibility:hidden"
    >
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    class="mobile-nav-link font-serif text-3xl text-main"
                >
                    {item.label}
                </a>
            ))
        }
        <a href="#pricing" class="pill-btn pill-btn--primary mt-6">
            <span>✳︎</span> Reservar
        </a>
    </div>
</header>

<div class="h-[90px]"></div>

<script>
    import { gsap } from "gsap";
    document.addEventListener("DOMContentLoaded", () => {
        const nav = document.getElementById("main-nav");
        const toggle = document.getElementById("mobile-menu-toggle");
        const mobileMenu = document.getElementById("mobile-menu");
        const lines = document.querySelectorAll(".hamburger-line");
        const navLogo = document.getElementById("nav-logo");
        let isOpen = false;
        if (nav) {
            window.addEventListener("scroll", () => {
                if (window.scrollY > 80) {
                    nav.style.backgroundColor = "rgba(249,246,240,0.95)";
                    nav.style.backdropFilter = "blur(12px)";
                    nav.style.boxShadow = "0 1px 0 rgba(0,0,0,0.05)";
                } else {
                    nav.style.backgroundColor = "transparent";
                    nav.style.backdropFilter = "none";
                    nav.style.boxShadow = "none";
                }
            });
        }
        if (toggle && mobileMenu) {
            toggle.addEventListener("click", () => {
                isOpen = !isOpen;
                if (isOpen) {
                    mobileMenu.style.visibility = "visible";
                    mobileMenu.style.opacity = "1";
                    mobileMenu.style.pointerEvents = "auto";
                    gsap.to(lines[0], { rotation: 45, y: 4, duration: 0.3 });
                    gsap.to(lines[1], { rotation: -45, y: -4, duration: 0.3 });
                    gsap.from(".mobile-nav-link", {
                        y: 30,
                        opacity: 0,
                        stagger: 0.08,
                        duration: 0.5,
                        ease: "power2.out",
                    });
                } else {
                    mobileMenu.style.opacity = "0";
                    mobileMenu.style.pointerEvents = "none";
                    setTimeout(() => {
                        mobileMenu.style.visibility = "hidden";
                    }, 500);
                    gsap.to(lines[0], { rotation: 0, y: 0, duration: 0.3 });
                    gsap.to(lines[1], { rotation: 0, y: 0, duration: 0.3 });
                }
            });
            mobileMenu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    if (isOpen) toggle.click();
                });
            });
        }
    });
</script>
