<!-- ============================================= -->
<!-- MOBILE FULL-SCREEN CARD MENU (Benjamin style) -->
<!-- ============================================= -->
<div
    id="mobile-card-menu"
    class="fixed inset-0 z-[101] pointer-events-none opacity-0 flex items-start justify-end p-3 pt-3"
>
    <div
        id="mobile-card"
        class="mobile-card-surface w-full overflow-hidden flex flex-col relative"
    >
        <!-- Navigation Items (card has no header — logo/close stay in floating bar above) -->
        <nav class="flex flex-col px-6 pt-20 pb-4 gap-1 flex-1">
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class="mobile-card-link flex items-baseline gap-3 py-3 group custom-cursor-hover"
                    >
                        <span class="font-mono text-[12px] text-main/30 tracking-wider group-hover:text-accent-luxury transition-colors duration-300">
                            {item.number}
                        </span>
                        <span class="font-serif text-[32px] md:text-[36px] text-main font-medium leading-none tracking-tight group-hover:text-accent-luxury transition-colors duration-300">
                            {item.label}
                        </span>
                    </a>
                ))
            }
        </nav>

        <!-- Card Footer -->
        <div
            class="px-6 py-5 border-t border-main/8 flex items-center justify-between"
        >
            <div class="flex items-center gap-5">
                <a
                    href="https://www.instagram.com/nrbalance"
                    target="_blank"
                    rel="noopener"
                    class="font-sans text-[13px] text-main/50 hover:text-main transition-colors custom-cursor-hover"
                >
                    Instagram
                </a>
                <a
                    href="https://wa.me/34600000000"
                    target="_blank"
                    rel="noopener"
                    class="font-sans text-[13px] text-main/50 hover:text-main transition-colors custom-cursor-hover"
                >
                    WhatsApp
                </a>
            </div>
            <a
                href="/#pricing"
                class="pill-btn pill-btn--primary text-[12px] custom-cursor-hover mobile-card-link"
            >
                <span>✳︎</span> Reservar
            </a>
        </div>
    </div>
</div>

<style>
    /* Benjamin Jochims-style menu: ::before pseudo-element grows from button size to full */
    .mobile-card-surface {
        z-index: 1;
    }
    .mobile-card-surface::before {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 48px;
        height: 48px;
        background: var(--color-secondary);
        border-radius: 32px;
        transform: translate(-4px, 4px);
        transition: all 0.75s cubic-bezier(0.76, 0, 0.24, 1);
        z-index: -1;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.2);
    }
    .mobile-card-surface.is-open::before {
        width: 100%;
        height: 100%;
        border-radius: 28px;
        transform: translate(0, 0);
    }

    /* 3D perspective for rotateX text reveal */
    .mobile-card-surface nav {
        perspective: 600px;
    }
    .mobile-card-link {
        transform-origin: top center;
    }
</style>

<script>
    import { gsap } from "gsap";

    document.addEventListener("astro:page-load", () => {
        const navBar = document.getElementById("nav-bar");
        const desktopToggle = document.getElementById("menu-toggle");
        const backdrop = document.getElementById("nav-backdrop");
        const menuLabel = document.getElementById("menu-label");

        // Desktop dropdown elements
        const dropdown = document.getElementById("nav-dropdown");
        const desktopLinks = document.querySelectorAll(
            "#nav-dropdown .nav-dropdown-link",
        );

        // Mobile elements
        const mobileToggle = document.getElementById("mobile-menu-toggle");
        const mobileCard = document.getElementById("mobile-card-menu");
        const mobileCardInner = document.getElementById("mobile-card");
        const mobileClose = document.getElementById("mobile-close");
        const mobileLinks = document.querySelectorAll(".mobile-card-link");
        const hamburgerLines = document.querySelectorAll(
            ".mobile-hamburger-line",
        );

        let isOpen = false;

        // =========== OPEN MENU ===========
        function openMenu() {
            isOpen = true;

            if (mobileCard && mobileCardInner) {
                // Show card with Benjamin-style animation
                mobileCard.style.pointerEvents = "auto";
                mobileCard.style.opacity = "1";
                document.body.style.overflow = "hidden";

                // Animate hamburger to X (mobile only)
                if (hamburgerLines.length >= 2) {
                    gsap.to(hamburgerLines[0], {
                        rotation: 45,
                        y: 3.5,
                        duration: 0.3,
                    });
                    gsap.to(hamburgerLines[1], {
                        rotation: -45,
                        y: -3.5,
                        duration: 0.3,
                    });
                }

                // Update desktop label
                if (menuLabel) menuLabel.textContent = "Cerrar";

                // Add 'open' class to trigger CSS ::before transition
                mobileCardInner.classList.add("is-open");

                // Stagger links with rotateX reveal (Benjamin style)
                gsap.fromTo(
                    mobileLinks,
                    { rotateX: 90, y: 40, opacity: 0 },
                    {
                        rotateX: 0,
                        y: 0,
                        opacity: 1,
                        stagger: 0.1,
                        duration: 0.6,
                        ease: "cubic-bezier(.215,.61,.355,1)",
                        delay: 0.55,
                    },
                );
            }
        }

        // =========== CLOSE MENU ===========
        function closeMenu() {
            isOpen = false;

            if (mobileCard && mobileCardInner) {
                document.body.style.overflow = "";

                // Animate hamburger back (mobile only)
                if (hamburgerLines.length >= 2) {
                    gsap.to(hamburgerLines[0], {
                        rotation: 0,
                        y: 0,
                        duration: 0.3,
                    });
                    gsap.to(hamburgerLines[1], {
                        rotation: 0,
                        y: 0,
                        duration: 0.3,
                    });
                }

                // Update desktop label
                if (menuLabel) menuLabel.textContent = "Menú";

                // Remove 'open' class — CSS transition handles collapse
                mobileCardInner.classList.remove("is-open");

                // Hide links immediately
                gsap.to(mobileLinks, { opacity: 0, y: -20, duration: 0.2 });

                // Wait for CSS transition to finish, then hide container
                setTimeout(() => {
                    mobileCard.style.pointerEvents = "none";
                    mobileCard.style.opacity = "0";
                }, 750);
            }
        }

        // Toggle listeners
        desktopToggle?.addEventListener("click", () => {
            if (isOpen) closeMenu();
            else openMenu();
        });
        mobileToggle?.addEventListener("click", () => {
            if (isOpen) closeMenu();
            else openMenu();
        });

        // Close on mobile X button
        mobileClose?.addEventListener("click", closeMenu);

        // Close on backdrop click
        backdrop?.addEventListener("click", closeMenu);

        // Close on any link click
        [...mobileLinks, ...desktopLinks].forEach((link) => {
            link.addEventListener("click", () => {
                if (isOpen) closeMenu();
            });
        });

        // Scroll behavior: subtle shadow on scroll (desktop only)
        window.addEventListener("scroll", () => {
            if (navBar) {
                navBar.style.boxShadow =
                    window.scrollY > 60
                        ? "0 8px 32px rgba(0,0,0,0.08)"
                        : "0 4px 30px rgba(0,0,0,0.06)";
            }
        });

        // =========== MOBILE: Logo color adaptation based on background ===========
        const mobileNavHeader = document.getElementById("mobile-nav-header");
        const mobileLogo = mobileNavHeader?.querySelector("svg");
        const mobileMenuBtn = document.getElementById("mobile-menu-toggle");

        function getLuminance(r: number, g: number, b: number): number {
            const [rs, gs, bs] = [r, g, b].map((c) => {
                c /= 255;
                return c <= 0.03928
                    ? c / 12.92
                    : Math.pow((c + 0.055) / 1.055, 2.4);
            });
            return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
        }

        function parseRgb(bg: string): [number, number, number, number] | null {
            const m = bg.match(
                /rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/,
            );
            if (!m) return null;
            return [
                parseInt(m[1]),
                parseInt(m[2]),
                parseInt(m[3]),
                m[4] !== undefined ? parseFloat(m[4]) : 1,
            ];
        }

        function getEffectiveBgColor(
            el: Element | null,
        ): [number, number, number] {
            // Walk up the DOM tree to find the first non-transparent background
            let current = el;
            while (current && current !== document.documentElement) {
                const bg = window.getComputedStyle(current).backgroundColor;
                const parsed = parseRgb(bg);
                if (parsed) {
                    const [r, g, b, a] = parsed;
                    if (a > 0.1) {
                        // Has a visible background color
                        return [r, g, b];
                    }
                }
                current = current.parentElement;
            }
            // Fallback: assume light background (base ~249,246,240)
            return [249, 246, 240];
        }

        function isDarkAtPoint(x: number, y: number): boolean {
            if (!mobileNavHeader) return false;

            // Temporarily hide our nav so elementFromPoint sees through it
            mobileNavHeader.style.visibility = "hidden";
            const el = document.elementFromPoint(x, y);
            mobileNavHeader.style.visibility = "";

            if (!el) return false;

            const [r, g, b] = getEffectiveBgColor(el);
            return getLuminance(r, g, b) < 0.35;
        }

        let lastDarkState: boolean | null = null;

        function updateNavColors() {
            if (isOpen) return;

            // Sample two points: one near logo (left side), one near hamburger (right side)
            const logoX = 60;
            const btnX = window.innerWidth - 30;
            const sampleY = 28;

            const logoDark = isDarkAtPoint(logoX, sampleY);
            const btnDark = isDarkAtPoint(btnX, sampleY);

            // Update logo color
            if (logoDark !== lastDarkState) {
                lastDarkState = logoDark;
                if (logoDark) {
                    mobileLogo?.classList.remove("text-main");
                    mobileLogo?.classList.add("text-base");
                } else {
                    mobileLogo?.classList.remove("text-base");
                    mobileLogo?.classList.add("text-main");
                }
            }

            // Update hamburger button (independently)
            if (mobileMenuBtn) {
                if (btnDark) {
                    mobileMenuBtn.style.backgroundColor =
                        "rgba(249,246,240,0.15)";
                    mobileMenuBtn.style.backdropFilter = "blur(10px)";
                    mobileMenuBtn.style.borderColor = "rgba(249,246,240,0.2)";
                } else {
                    mobileMenuBtn.style.backgroundColor = "";
                    mobileMenuBtn.style.backdropFilter = "";
                    mobileMenuBtn.style.borderColor = "";
                }
            }
        }

        // Run on scroll + initial
        if (mobileNavHeader) {
            let rafId = 0;
            window.addEventListener(
                "scroll",
                () => {
                    cancelAnimationFrame(rafId);
                    rafId = requestAnimationFrame(updateNavColors);
                },
                { passive: true },
            );
            requestAnimationFrame(updateNavColors);
        }
    });
</script>
