---
import MainLayout from "../../layouts/MainLayout.astro";

// Mock data for Admin MVP while Astro DB establishes the connection
const appointments = [
    {
        id: "1",
        clientName: "María García",
        clientPhone: "+34 600 123 456",
        serviceName: "Masaje Tejido Profundo",
        date: new Date().toISOString(),
        time: "10:30",
        status: "confirmed",
    },
];

// Temporary: No real auth for this MVP, just a hidden route.
---

<MainLayout title="Admin Panel | NR Balance" hideNav={true} hideFooter={true}>
    <div class="min-h-screen bg-secondary flex text-main">
        <!-- Sidebar -->
        <aside
            class="w-64 bg-base border-r border-main/10 flex flex-col justify-between p-6"
        >
            <div>
                <div class="mb-10">
                    <span class="font-serif text-[24px]">NR Balance</span>
                    <span
                        class="block text-[10px] font-mono uppercase tracking-widest text-main/50 mt-1"
                        >Admin Dashboard</span
                    >
                </div>
                <nav class="flex flex-col gap-2">
                    <a
                        href="#"
                        class="px-4 py-3 bg-peach/20 text-accent-luxury font-bold rounded-lg border border-accent-luxury/20 flex items-center gap-3"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path></svg
                        >
                        Agenda
                    </a>
                </nav>
            </div>
            <a
                href="/"
                class="text-[14px] text-main/60 hover:text-main flex items-center gap-2"
            >
                &larr; Volver a la web
            </a>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-10 overflow-auto">
            <header class="flex justify-between items-center mb-10">
                <div>
                    <h1 class="font-serif text-[32px] leading-none mb-2">
                        Agenda de Citas
                    </h1>
                    <p class="text-[14px] text-main/60">
                        Gestiona las reservas de tus pacientes.
                    </p>
                </div>
            </header>

            <div
                class="bg-base rounded-2xl border border-main/10 overflow-hidden shadow-sm"
            >
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr
                            class="bg-main/5 border-b border-main/10 text-[12px] uppercase tracking-widest text-main/60"
                        >
                            <th class="p-4 font-normal">Fecha y Hora</th>
                            <th class="p-4 font-normal">Paciente</th>
                            <th class="p-4 font-normal">Servicio</th>
                            <th class="p-4 font-normal">Estado</th>
                            <th class="p-4 font-normal text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-[14px]">
                        {
                            appointments.length === 0 ? (
                                <tr>
                                    <td
                                        colspan="5"
                                        class="p-8 text-center text-main/50 italic"
                                    >
                                        No hay citas reservadas aún.
                                    </td>
                                </tr>
                            ) : (
                                appointments.map((app) => (
                                    <tr class="border-b border-main/5 hover:bg-main/5 transition-colors">
                                        <td class="p-4">
                                            <div class="flex flex-col">
                                                <span class="font-bold">
                                                    {app.date
                                                        ? new Date(
                                                              app.date,
                                                          ).toLocaleDateString(
                                                              "es-ES",
                                                          )
                                                        : "--"}
                                                </span>
                                                <span class="text-[12px] text-main/60">
                                                    {app.time || "--"}
                                                </span>
                                            </div>
                                        </td>
                                        <td class="p-4">
                                            <div class="flex flex-col">
                                                <span class="font-bold">
                                                    {app.clientName}
                                                </span>
                                                <span class="text-[12px] text-main/60">
                                                    {app.clientPhone}
                                                </span>
                                            </div>
                                        </td>
                                        <td class="p-4">
                                            <div class="flex flex-col">
                                                <span>{app.serviceName}</span>
                                            </div>
                                        </td>
                                        <td class="p-4">
                                            <span
                                                class={`px-3 py-1 text-[10px] uppercase tracking-widest rounded-full font-bold ${app.status === "confirmed" ? "bg-green-100 text-green-700 border border-green-200" : "bg-orange-100 text-orange-700 border border-orange-200"}`}
                                            >
                                                {app.status}
                                            </span>
                                        </td>
                                        <td class="p-4 text-right">
                                            <button class="text-accent-luxury hover:underline text-[12px] uppercase tracking-widest font-bold">
                                                Ver Detalles
                                            </button>
                                        </td>
                                    </tr>
                                ))
                            )
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</MainLayout>
