---
// About.astro — Pinned Image & Sticky Text
---

<section id="about" class="py-0 relative bg-base">
    <div class="flex flex-col md:flex-row relative w-full items-start">
        <!-- Sticky Image Panel -->
        <div
            class="about-image-pin w-full md:w-1/2 sticky top-0 h-[50vh] md:h-screen overflow-hidden"
        >
            <img
                src="/about_studio.png"
                alt="NR Balance estudio"
                class="w-full h-full object-cover scale-110"
                loading="lazy"
            />
            <div class="absolute inset-0 bg-main/10 mix-blend-multiply"></div>
        </div>

        <!-- Scrolling Text Panel -->
        <div
            class="w-full md:w-1/2 flex flex-col justify-center px-8 md:px-16 lg:px-24 py-24 md:py-0 md:min-h-[150vh] z-10 bg-base"
        >
            <div
                class="about-text-content md:sticky md:top-1/2 md:-translate-y-1/2"
            >
                <span
                    class="text-[12px] font-bold tracking-[0.2em] uppercase text-main/50 mb-6 block"
                >
                    El Estudio
                </span>
                <p
                    class="font-serif text-[26px] md:text-[36px] lg:text-[42px] leading-[1.3] text-main tracking-tight mb-10"
                >
                    NR Balance nace de la convicción de que el cuerpo y la mente
                    son inseparables. Un santuario de bienestar en el que el
                    masaje terapéutico y el acompañamiento emocional convergen
                    para restaurar tu paz interior, a tu propio ritmo.
                </p>
                <a href="#about" class="pill-btn pill-btn--outline w-fit">
                    <span class="text-accent-luxury text-[14px]">✳︎</span>
                    Conócenos mejor
                </a>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);

        // Image Parallax on Sticky
        gsap.to(".about-image-pin img", {
            yPercent: 10,
            ease: "none",
            scrollTrigger: {
                trigger: "#about",
                start: "top bottom",
                end: "bottom top",
                scrub: true,
            },
        });

        // Text reveal stagger
        gsap.from(".about-text-content > *", {
            y: 40,
            opacity: 0,
            duration: 1,
            stagger: 0.15,
            ease: "power3.out",
            scrollTrigger: {
                trigger: ".about-text-content",
                start: "top 80%",
            },
        });
    });
</script>
