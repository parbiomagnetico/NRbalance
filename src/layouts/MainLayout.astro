---
import "@fontsource/archivo";
import "@fontsource/gotu";
import "@fontsource/league-script";
import "../styles/global.css";

import SmoothScroll from "../components/SmoothScroll.astro";
import Navigation from "../components/Navigation.astro";

interface Props {
    title: string;
    hideNav?: boolean;
    hideFooter?: boolean;
}

const { title, hideNav = false, hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="NR Balance — Especialistas en Masaje de Tejido Profundo, Descompresión Física y Psicología Clínica en Madrid. Recupera tu equilibrio físico y mental."
        />
        <meta
            name="keywords"
            content="masaje profundo, psicología clínica, dolor lumbar, bruxismo, ansiedad, estrés, terapia somática, madrid, nr balance"
        />
        <meta property="og:title" content={title} />
        <meta
            property="og:description"
            content="Especialistas en fisiología, biomecánica y psicología clínica. Protocolos enfocados en resultados."
        />
        <meta property="og:type" content="website" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <SmoothScroll />
        {!hideNav && <Navigation />}

        <div id="custom-cursor" class="custom-cursor"></div>
        <div class="grain-overlay"></div>

        <slot />

        {
            !hideFooter && (
                <button
                    id="scroll-up-btn"
                    class="fixed bottom-8 right-8 z-50 w-12 h-12 rounded-full bg-white shadow-lg flex flex-col items-center justify-center text-main text-xs font-sans font-semibold opacity-0 translate-y-4 pointer-events-none transition-all duration-500 hover:shadow-xl hover:-translate-y-1"
                    aria-label="Volver arriba"
                >
                    <span class="text-[10px] leading-none">▲</span>
                    <span class="text-[10px] leading-none tracking-wider">
                        UP
                    </span>
                </button>
            )
        }

        <script>
            import { gsap } from "gsap";

            document.addEventListener("DOMContentLoaded", () => {
                const cursor = document.getElementById("custom-cursor");
                if (!cursor) return;

                // 1. Detección de Mobile/Touch temprana
                const isTouchDevice =
                    "ontouchstart" in window || navigator.maxTouchPoints > 0;
                if (isTouchDevice || window.innerWidth <= 1024) {
                    cursor.style.display = "none";
                    return;
                }

                // 2. GSAP QuickSetter para máximo rendimiento (AAA feel)
                const xSetter = gsap.quickSetter(cursor, "x", "px");
                const ySetter = gsap.quickSetter(cursor, "y", "px");

                let isVisible = false;

                const onMouseMove = (e: MouseEvent) => {
                    if (!isVisible) {
                        cursor.classList.add("visible");
                        isVisible = true;
                    }
                    // Suavizado sutil mediante GSAP (puedes ajustar el duration si quieres más/menos lag)
                    gsap.to(
                        {},
                        {
                            duration: 0,
                            onUpdate: () => {
                                xSetter(e.clientX);
                                ySetter(e.clientY);
                            },
                        },
                    );
                };

                window.addEventListener("mousemove", onMouseMove);

                // 3. Manejo de salida/entrada de ventana (Evita el punto "pegado")
                document.addEventListener("mouseleave", () => {
                    cursor.classList.remove("visible");
                    isVisible = false;
                });

                document.addEventListener("mouseenter", () => {
                    // Esperamos al primer mousemove para re-activar
                });

                // 4. Setup de Hovers (delegación o reactivo a cambios de página)
                const setupHovers = () => {
                    const hoverElements = document.querySelectorAll(
                        "a, button, input, select, textarea, .custom-cursor-hover, .service-option, .time-slot",
                    );

                    hoverElements.forEach((el) => {
                        el.addEventListener("mouseenter", () =>
                            cursor.classList.add("hovering"),
                        );
                        el.addEventListener("mouseleave", () =>
                            cursor.classList.remove("hovering"),
                        );
                    });
                };

                setupHovers();

                // Compatibilidad con transiciones de Astro (View Transitions)
                document.addEventListener("astro:page-load", setupHovers);

                // Exportar para componentes dinámicos (como el Booking)
                (window as any).refreshCustomCursor = setupHovers;

                // 5. Botón Scroll Up
                const upBtn = document.getElementById("scroll-up-btn");
                if (upBtn) {
                    window.addEventListener("scroll", () => {
                        if (window.scrollY > 600) {
                            gsap.to(upBtn, {
                                opacity: 1,
                                y: 0,
                                pointerEvents: "auto",
                                duration: 0.4,
                            });
                        } else {
                            gsap.to(upBtn, {
                                opacity: 0,
                                y: 20,
                                pointerEvents: "none",
                                duration: 0.4,
                            });
                        }
                    });
                    upBtn.addEventListener("click", () =>
                        window.scrollTo({ top: 0, behavior: "smooth" }),
                    );
                }
            });
        </script>
    </body>
</html>
