            </div>

            <!-- Horizontal Nav Links -->
            <nav
                class="flex flex-wrap items-center justify-center gap-6 md:gap-10 mb-8 md:mb-10"
            >
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class="font-sans text-[14px] md:text-[16px] text-main/80 hover:text-accent-luxury transition-colors duration-300 tracking-[0.3px]"
                        >
                            {link.label}
                        </a>
                    ))
                }
            </nav>

            <!-- Slogan -->
            <h4
                class="font-serif text-[22px] md:text-[28px] tracking-tight text-main mb-8 md:mb-10"
            >
                Invierte en salud
            </h4>

            <!-- Social Icons -->
            <div class="flex items-center gap-5 mb-10 md:mb-14">
                <!-- Facebook -->
                <a
                    href="#"
                    class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center text-main/70 hover:bg-accent-luxury hover:text-white transition-all duration-300"
                    aria-label="Facebook"
                >
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"
