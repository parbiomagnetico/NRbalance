---
// Services.astro - Horizontal Scroll Awwwards Experience
const psychServices = [
    {
        title: "Psicoterapia Individual",
        tag: "Sesión 60 mins",
        desc: "Un espacio seguro para explorar el origen del malestar emocional, ansiedad o patrones limitantes, utilizando técnicas cognitivas y somáticas.",
    },
    {
        title: "Gestión de Trauma",
        tag: "Enfoque Integrativo",
        desc: "Acompañamiento especializado para procesar vivencias traumáticas que han quedado atrapadas en el cuerpo y en la memoria.",
    },
];

const manualServices = [
    {
        title: "Masaje de Tejido Profundo",
        tag: "Restauración Física",
        desc: "Técnica intensa enfocada en las capas más profundas del músculo y la fascia, ideal para dolor crónico y tensión severa.",
    },
    {
        title: "Liberación Somática",
        tag: "Cuerpo & Emoción",
        desc: "Una fusión donde el tacto acompaña la liberación emocional. El cuerpo suelta lo que la mente ya no necesita sostener.",
    },
];
---

<!-- El contenedor padre será el "trigger" del pin y usará h-screen -->
<section
    id="services-pin"
    class="bg-main text-base relative h-screen w-full overflow-hidden"
>
    <!-- El "track" contendrá X paneles (100vw cada uno). Se moverá horizontalmente. -->
    <div id="services-track" class="flex h-full w-[300vw] lg:w-[250vw]">
        <!-- Panel 1: Intro -->
        <div
            class="panel h-full w-screen shrink-0 relative flex flex-col items-center justify-center p-8 md:p-24 overflow-hidden border-r border-base/10"
        >
            <h2
                class="font-serif text-[60px] md:text-[100px] leading-[0.9] tracking-tighter text-peach text-center z-10 custom-cursor-hover"
            >
                Nuestros<br /><span class="text-base/90 italic font-light"
                    >Tratamientos</span
                >
            </h2>
            <p
                class="mt-8 text-base/60 text-center max-w-sm uppercase tracking-widest text-[10px] hidden md:block z-10"
            >
                ( Scroll to discover )
            </p>
        </div>

        <!-- Panel 2: Psicología -->
        <div
            class="panel h-full w-screen shrink-0 relative flex flex-col justify-center p-8 md:p-24 bg-secondary overflow-hidden"
        >
            <div class="absolute inset-0 z-0">
                <img
                    src="/psych_services.png"
                    class="w-full h-full object-cover opacity-20 mix-blend-multiply grayscale"
                    alt="Psicología"
                />
            </div>

            <div
                class="relative z-10 w-full max-w-4xl max-h-full flex flex-col"
            >
                <h3
                    class="font-sans text-[12px] md:text-[16px] font-bold tracking-[0.3em] uppercase text-main/60 mb-8 md:mb-16 border-b border-main/20 pb-6"
                >
                    I. Psicología Clínica
                </h3>

                <div
                    class="flex flex-col gap-6 md:gap-10 overflow-y-auto no-scrollbar pb-10"
                >
                    {
                        psychServices.map((srv) => (
                            <div class="group relative flex flex-col md:flex-row md:items-start justify-between gap-4 md:gap-12 custom-cursor-hover">
                                <div class="flex flex-col gap-2 md:w-[60%]">
                                    <span class="text-accent-luxury text-[10px] md:text-[12px] font-mono tracking-widest">
                                        {srv.tag}
                                    </span>
                                    <h4 class="font-serif text-[28px] md:text-[50px] leading-[1] tracking-tight text-main group-hover:italic transition-all duration-500">
                                        {srv.title}
                                    </h4>
                                </div>
                                <p class="text-[14px] md:text-[16px] text-main/70 leading-[1.6] md:w-[40%] md:pt-4">
                                    {srv.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Panel 3: Terapia Manual -->
        <div
            class="panel h-full w-screen shrink-0 relative flex flex-col justify-center p-8 md:p-24 bg-peach/30 overflow-hidden"
        >
            <div class="absolute inset-0 z-0">
                <img
                    src="/premium_massage.png"
                    class="w-full h-full object-cover opacity-20 mix-blend-multiply grayscale"
                    alt="Masaje"
                />
            </div>

            <div
                class="relative z-10 w-full max-w-4xl max-h-full flex flex-col"
            >
                <h3
                    class="font-sans text-[12px] md:text-[16px] font-bold tracking-[0.3em] uppercase text-main/60 mb-8 md:mb-16 border-b border-main/20 pb-6"
                >
                    II. Terapia Manual Avanzada
                </h3>

                <div
                    class="flex flex-col gap-6 md:gap-10 overflow-y-auto no-scrollbar pb-10"
                >
                    {
                        manualServices.map((srv) => (
                            <div class="group relative flex flex-col md:flex-row md:items-start justify-between gap-4 md:gap-12 custom-cursor-hover">
                                <div class="flex flex-col gap-2 md:w-[60%]">
                                    <span class="text-accent-luxury text-[10px] md:text-[12px] font-mono tracking-widest">
                                        {srv.tag}
                                    </span>
                                    <h4 class="font-serif text-[28px] md:text-[50px] leading-[1] tracking-tight text-main group-hover:italic transition-all duration-500">
                                        {srv.title}
                                    </h4>
                                </div>
                                <p class="text-[14px] md:text-[16px] text-main/70 leading-[1.6] md:w-[40%] md:pt-4">
                                    {srv.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);

        const track = document.getElementById("services-track");
        const panels = gsap.utils.toArray(".panel");

        if (track) {
            // Horizontal Scroll Animation
            let tl = gsap.timeline({
                scrollTrigger: {
                    trigger: "#services-pin",
                    start: "top top",
                    // The end defines how long the scroll takes.
                    // Making it "+=" double the track width makes the scroll slow and pleasurable.
                    end: () => "+=" + track.offsetWidth,
                    scrub: 1.5, // 1.5s lag for smooth butter feel
                    pin: true,
                    anticipatePin: 1,
                },
            });

            tl.to(panels, {
                xPercent: -100 * (panels.length - 1),
                ease: "none",
            });

            // Image Parallax within the horizontal panels
            panels.forEach((panel: any) => {
                const img = panel.querySelector("img");
                if (img) {
                    gsap.fromTo(
                        img,
                        { x: -50 },
                        {
                            x: 50,
                            ease: "none",
                            scrollTrigger: {
                                trigger: "#services-pin",
                                start: "top top",
                                end: () => "+=" + track.offsetWidth,
                                scrub: true,
                            },
                        },
                    );
                }
            });
        }
    });
</script>
