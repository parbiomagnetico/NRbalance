---
// Footer.astro — Exact yogui.es footer replica for NR Balance
// Structure:
// 1. "Transformación de cuerpo & mente" hero section with photo
// 2. Logo centered
// 3. footer-circle.svg as background behind bottom section
// 4. Horizontal nav links
// 5. "Invierte en salud" slogan
// 6. Social icons in circles
// 7. Address + legal links

const navLinks = [
    { label: "Conócenos", href: "#about" },
    { label: "Horarios", href: "#" },
    { label: "Suscripción", href: "#pricing" },
    { label: "Servicios", href: "#services" },
    { label: "Blog", href: "#" },
    { label: "Tienda", href: "#" },
];
