            class="absolute inset-0 flex items-center justify-center pointer-events-none"
        >
            <img
                src="/footer-circle.svg"
                alt=""
                class="w-[500px] md:w-[650px] lg:w-[760px] h-auto opacity-80"
                aria-hidden="true"
